# managed by metrics-stack-alloy
# Local edits survive package upgrades: this file ships as
# %config(noreplace) (rpm) / a conffile (deb).
#
# Where alloy ships logs. The default is right when metrics-stack-loki runs
# on this same host; for a remote Loki server, change the host and:
#   systemctl restart alloy
LOKI_URL=http://127.0.0.1:3100/loki/api/v1/push
