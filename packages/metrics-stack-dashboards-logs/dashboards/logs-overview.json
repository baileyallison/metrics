     "refId": "A",
     "queryType": "range",
     "legendFormat": "{{unit}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "custom": {
      "drawStyle": "bars",
      "stacking": {
       "mode": "normal"
      }
     },
     "unit": "short"
    },
    "overrides": []
   },
   "id": 5
  },
  {
