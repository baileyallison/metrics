  {
   "type": "timeseries",
   "title": "Log Volume by Host",
   "datasource": {
    "type": "loki",
    "uid": "loki"
   },
   "gridPos": {
    "x": 12,
    "y": 12,
    "w": 12,
    "h": 8
   },
   "targets": [
    {
     "datasource": {
      "type": "loki",
      "uid": "loki"
     },
     "expr": "sum by (host) (count_over_time({job=~\"systemd-journal|varlog\", host=~\"$host\"}[$__auto]))",
     "refId": "A",
