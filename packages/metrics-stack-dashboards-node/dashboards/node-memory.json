          },
          "expr": "node_memory_PageTables_bytes{instance=~\"$instance\"}",
          "refId": "B",
          "legendFormat": "Page Tables"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "id": 9
    },
    {
      "type": "timeseries",
      "title": "Dirty & Writeback",
      "datasource": {
