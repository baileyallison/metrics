        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "node_memory_Slab_bytes{instance=~\"$instance\"}",
          "refId": "A",
          "legendFormat": "Slab"
        },
        {
          "datasource": {
