      },
      "id": 7
    },
    {
      "type": "timeseries",
      "title": "Receive / Transmit Drops",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(node_network_receive_drop_total{instance=~\"$instance\",device!=\"lo\"}[5m])",
          "refId": "A",
