{
  "id": null,
  "uid": "node-disk",
  "title": "Node Disk",
  "tags": [
    "monitoring-stack",
    "node-exporter"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "links": [
    {
      "title": "Overview",
      "type": "link",
      "icon": "dashboard",
      "url": "/d/node-overview",
      "tooltip": "Node Overview",
      "keepTime": true,
      "includeVars": true,
      "targetBlank": false
    },
    {
      "title": "CPU",
      "type": "link",
      "icon": "dashboard",
      "url": "/d/node-cpu",
      "tooltip": "CPU detail",
      "keepTime": true,
      "includeVars": true,
      "targetBlank": false
    },
    {
      "title": "Memory",
      "type": "link",
      "icon": "dashboard",
      "url": "/d/node-memory",
      "tooltip": "Memory detail",
      "keepTime": true,
      "includeVars": true,
      "targetBlank": false
    },
    {
      "title": "Network",
      "type": "link",
      "icon": "dashboard",
      "url": "/d/node-network",
      "tooltip": "Network detail",
      "keepTime": true,
      "includeVars": true,
      "targetBlank": false
    }
  ],
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(node_uname_info, instance)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Root FS Used",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "100 - (node_filesystem_avail_bytes{instance=~\"$instance\",mountpoint=\"/\",fstype!=\"rootfs\"} / node_filesystem_size_bytes{instance=~\"$instance\",mountpoint=\"/\",fstype!=\"rootfs\"} * 100)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "id": 1
    },
    {
      "type": "stat",
      "title": "Root FS Free",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "node_filesystem_avail_bytes{instance=~\"$instance\",mountpoint=\"/\",fstype!=\"rootfs\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "id": 2
    },
    {
      "type": "stat",
      "title": "Disk Read Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(node_disk_read_bytes_total{instance=~\"$instance\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "id": 3
    },
    {
      "type": "stat",
      "title": "Disk Write Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(node_disk_written_bytes_total{instance=~\"$instance\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "id": 4
    },
    {
      "type": "timeseries",
      "title": "Filesystem Used",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "1 - (node_filesystem_avail_bytes{instance=~\"$instance\",fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{instance=~\"$instance\",fstype!~\"tmpfs|overlay\"})",
          "refId": "A",
          "legendFormat": "{{mountpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "id": 5
    },
    {
      "type": "timeseries",
      "title": "Inode Usage",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "1 - (node_filesystem_files_free{instance=~\"$instance\",fstype!~\"tmpfs|overlay\"} / node_filesystem_files{instance=~\"$instance\",fstype!~\"tmpfs|overlay\"})",
          "refId": "A",
          "legendFormat": "{{mountpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "id": 6
    },
    {
      "type": "timeseries",
      "title": "Disk I/O Bytes",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(node_disk_read_bytes_total{instance=~\"$instance\"}[5m])",
          "refId": "A",
          "legendFormat": "Read {{device}}"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(node_disk_written_bytes_total{instance=~\"$instance\"}[5m])",
          "refId": "B",
          "legendFormat": "Write {{device}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        },
        "overrides": []
      },
      "id": 7
    },
    {
      "type": "timeseries",
      "title": "Disk I/O Operations",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(node_disk_reads_completed_total{instance=~\"$instance\"}[5m])",
          "refId": "A",
          "legendFormat": "Reads {{device}}"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(node_disk_writes_completed_total{instance=~\"$instance\"}[5m])",
          "refId": "B",
          "legendFormat": "Writes {{device}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "iops"
        },
        "overrides": []
      },
      "id": 8
    },
    {
      "type": "timeseries",
      "title": "Disk Utilization",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(node_disk_io_time_seconds_total{instance=~\"$instance\"}[5m]) * 100",
          "refId": "A",
          "legendFormat": "{{device}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "id": 9
    },
    {
      "type": "timeseries",
      "title": "Disk I/O Latency",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(node_disk_read_time_seconds_total{instance=~\"$instance\"}[5m]) / rate(node_disk_reads_completed_total{instance=~\"$instance\"}[5m])",
          "refId": "A",
          "legendFormat": "Read {{device}}"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(node_disk_write_time_seconds_total{instance=~\"$instance\"}[5m]) / rate(node_disk_writes_completed_total{instance=~\"$instance\"}[5m])",
          "refId": "B",
          "legendFormat": "Write {{device}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "id": 10
    }
  ]
}
